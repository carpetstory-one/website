# ==============================================================================
# Carpetstory — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in values for local development.
# ==============================================================================

# ── Site URL ──
# Used for generating canonical URLs, OG images, and sitemaps.
# In production, set to your actual domain (e.g. https://carpetstory.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Resend (email delivery for inquiry form) ──
# Get your API key at https://resend.com
# If unset, the inquiry API route will log to console instead of sending email.
RESEND_API_KEY=

# ── Resend recipient ──
# The email address that receives inquiry form submissions.
RESEND_TO_EMAIL=hello@carpetstory.com

# ── Resend from ──
# The sender address for inquiry emails. Must be a verified domain in Resend.
RESEND_FROM_EMAIL=inquiry@carpetstory.com

# ── WhatsApp ──
# WhatsApp business number for the CTA buttons.
NEXT_PUBLIC_WHATSAPP_NUMBER=+919876543210

# ── Analytics ──
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Microsoft Clarity Project ID
NEXT_PUBLIC_CLARITY_ID=XXXXXXXXXX

# ── HubSpot ──
HUBSPOT_ACCESS_TOKEN=
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=

# ── Sanity ──
# Sanity Project ID and Dataset
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# ── Google Site Verification ──
GOOGLE_SITE_VERIFICATION=
